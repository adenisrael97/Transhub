# Copy to .env.local and adjust. NEXT_PUBLIC_* values are exposed to the browser.

# Backend API base URL (the Express server).
NEXT_PUBLIC_API_URL=http://localhost:4000

# ---------------------------------------------------------------------------
# Sentry (frontend monitoring) — ALL OPTIONAL. Leave the DSN empty to disable
# Sentry entirely (the SDK becomes a no-op; nothing is sent). A Sentry DSN is
# public by design, so exposing it via NEXT_PUBLIC_ is expected and safe.
# ---------------------------------------------------------------------------
# DSN from the "transhub-frontend" Sentry project (Settings → Client Keys).
NEXT_PUBLIC_SENTRY_DSN=
# Logical environment: development | staging | production. Defaults to NODE_ENV.
NEXT_PUBLIC_SENTRY_ENVIRONMENT=development
# Release identifier (e.g. git SHA) for regression tracking + source-map matching.
NEXT_PUBLIC_SENTRY_RELEASE=

# --- Source-map upload (build time only; NOT exposed to the browser) ---
# Required ONLY to upload source maps during `next build` (CI/production). When
# SENTRY_AUTH_TOKEN is unset, builds skip upload and still succeed.
SENTRY_ORG=adeniran-israel
SENTRY_PROJECT=transhub-frontend
SENTRY_AUTH_TOKEN=
