generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

// Lowercase to match the frontend's Role union exactly so JWT claims work
// with AuthGuard without any mapping.
enum Role {
  passenger
  operator
  admin
  driver
}

enum OperatorStatus {
  pending
  approved
  declined
}

enum SeatStatus {
  available
  held
  booked
}

enum TripStatus {
  scheduled
  active
  completed
  cancelled
}

enum BookingStatus {
  pending
  confirmed
  cancelled
  refunded
}

// ---------------------------------------------------------------------------
// Models
// ---------------------------------------------------------------------------

model User {
  id         String    @id @default(uuid())
  email      String    @unique
  password   String    // argon2id hash — never returned to clients
  fullName   String
  phone      String
  role       Role      @default(passenger)
  // Set only for role=operator. Null for passengers/admins/drivers.
  // @unique enforces the 1-to-1 with Operator.
  operatorId String?   @unique
  operator   Operator? @relation(fields: [operatorId], references: [id])
  bookings   Booking[]
  charters   Charter[]
  waybills   Waybill[]
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@map("users")
}

// A transport company's onboarding application.
// No User account is created until an admin approves the application,
// at which point a User with role=operator is created and linked here.
model Operator {
  id               String         @id @default(uuid())
  companyName      String
  contactName      String
  email            String         @unique
  phone            String
  city             String
  fleetSize        String
  vehicleTypes     String[]
  routes           String
  yearsInOperation String
  cacNumber        String
  additionalInfo   String?
  status           OperatorStatus @default(pending)
  appliedAt        DateTime       @default(now())
  reviewedAt       DateTime?
  // Back-references
  user             User?
  trips            Trip[]
  vehicles         Vehicle[]
  drivers          Driver[]

  @@map("operators")
}

// A driver employed by an operator. Created by the operator, never self-registered.
// Drivers authenticate with phone + password only (no email required).
// A driver's phone is globally unique so the JWT claim is unambiguous.
model Driver {
  id         String   @id @default(uuid())
  operatorId String
  operator   Operator @relation(fields: [operatorId], references: [id])
  fullName   String
  phone      String   @unique
  password   String   // argon2id hash — never returned to clients
  licenseNo  String?
  isActive   Boolean  @default(true)
  trips      Trip[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([operatorId])
  @@index([phone])
  @@map("drivers")
}

// A physical vehicle owned by an operator.
// Never hard-deleted — softDelete sets active=false.
model Vehicle {
  id         String   @id @default(uuid())
  operatorId String
  operator   Operator @relation(fields: [operatorId], references: [id])
  plate      String   @unique
  make       String
  model      String
  capacity   Int
  type       String   // 'bus' | 'minibus' | 'coaster' | 'van'
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([operatorId])
  @@map("vehicles")
}

// A scheduled bus journey offered by an operator.
// Seats are auto-created when the trip is created; no separate creation step.
model Trip {
  id            String     @id @default(uuid())
  from          String
  to            String
  departureTime DateTime
  arrivalTime   DateTime?
  price         Int        // price per seat in naira
  totalSeats    Int
  vehicleType   String
  // FK to Driver. Nullable — a trip may be created before a driver is assigned.
  // SetNull on delete so removing a driver doesn't cascade-delete trips.
  driverId      String?
  driver        Driver?    @relation(fields: [driverId], references: [id], onDelete: SetNull)
  parkName      String?    // bus terminal / park the journey departs from
  amenities     String[]   // features offered on the bus (AC, WiFi, etc.)
  status        TripStatus @default(scheduled)
  isActive      Boolean    @default(true)
  isFull        Boolean    @default(false)   // manual "marked full" override by operator/driver
  offlineCount  Int        @default(0)       // walk-in seats recorded offline at the bus park
  operatorId    String
  operator      Operator   @relation(fields: [operatorId], references: [id])
  seats         Seat[]
  bookings      Booking[]
  waybills      Waybill[]
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([from, to, departureTime])
  // Operator dashboard ("my trips") + the operatorId FK join. Postgres does NOT
  // auto-index FK columns, so without this every operator-scoped list/delete and
  // the analytics operator join falls back to a sequential scan of all trips.
  @@index([operatorId])
  @@map("trips")
}

// One physical seat on a specific trip.
// The unique constraint on (tripId, label) is the last-line-of-defense
// against double-booking — even a logic bug can't create two identical seats.
model Seat {
  id      String      @id @default(uuid())
  tripId  String
  trip    Trip        @relation(fields: [tripId], references: [id], onDelete: Cascade)
  label   String      // e.g. "A1", "B3"
  status  SeatStatus  @default(available)
  // When a 'held' seat's hold lapses. Set on hold, cleared on confirm/release.
  // The DB-side source of truth for the sweeper that reclaims orphaned holds
  // (e.g. if the per-hold BullMQ expiry job was never enqueued or Redis was lost).
  heldUntil DateTime?
  // WHO holds this seat. Durable, transactional source of truth for hold
  // ownership — Redis (seat_hold:*) is only a fast-path cache. Persisting this
  // means a transient Redis failure during hold can't lock a user out of seats
  // they legitimately hold: payment init verifies ownership against this column.
  // Set on hold, cleared (null) on confirm and on sweeper release.
  heldBy    String?
  booking BookedSeat?

  @@unique([tripId, label])
  // Supports the sweeper's `WHERE status='held' AND heldUntil < now()` scan.
  @@index([status, heldUntil])
  // Critical: seat availability count (`WHERE tripId=X AND status='available'`).
  // Hit on every /trips/:id page load and on hold validation.
  @@index([tripId, status])
  @@map("seats")
}

// A confirmed booking — one per checkout session.
// paymentRef is unique: webhook idempotency — same Paystack reference can't create two bookings.
model Booking {
  id          String          @id @default(uuid())
  userId      String
  user        User            @relation(fields: [userId], references: [id])
  tripId      String
  trip        Trip            @relation(fields: [tripId], references: [id])
  seats       BookedSeat[]
  passengers  PassengerInfo[]
  status      BookingStatus   @default(pending)
  totalAmount Int             // naira, sum of seats × price
  paymentRef  String?         @unique
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  // Supports analytics aggregates (status equality + createdAt range/grouping)
  // and any status-filtered booking lookup.
  @@index([status, createdAt])
  // Passenger "my bookings" list — most common read path after checkout.
  @@index([userId])
  // Trip-level booking queries (e.g. admin view, cancellation sweep).
  @@index([tripId])
  // Webhook idempotency lookup — paymentRef is already @unique (index implied),
  // but the explicit declaration makes the intent clear for future readers.
  @@map("bookings")
}

// Junction: one confirmed seat can belong to exactly one booking.
// The @unique on seatId is the DB-level last line of defence — a seat can only
// ever appear in one confirmed booking even if application logic has a bug.
model BookedSeat {
  id        String  @id @default(uuid())
  bookingId String
  booking   Booking @relation(fields: [bookingId], references: [id])
  seatId    String  @unique
  seat      Seat    @relation(fields: [seatId], references: [id])

  // Every booking/ticket read joins booked_seats by bookingId (Booking.seats
  // include). Unindexed FK → sequential scan that grows with total bookings.
  @@index([bookingId])
  @@map("booked_seats")
}

// Passenger details collected at checkout for each seat in a booking.
// Stored separately from User to support guest-booked seats (future) and
// to hold next-of-kin / special-needs info that belongs to the journey,
// not the account.
model PassengerInfo {
  id             String   @id @default(uuid())
  bookingId      String
  booking        Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  fullName       String
  phone          String
  email          String?
  nextOfKinName  String
  nextOfKinPhone String
  specialNeeds   String?
  createdAt      DateTime @default(now())

  @@index([bookingId])
  @@map("passenger_info")
}

// A charter request: a passenger hires an entire vehicle for a private journey.
// Flow: pending → quoted (admin sets price) → payment_pending → confirmed | cancelled.
model Charter {
  id             String    @id @default(uuid())
  passengerId    String
  passenger      User      @relation(fields: [passengerId], references: [id])
  vehicleType    String    // e.g. 'bus-33', 'coaster', 'suv' — whatever the UI sends
  fromLocation   String
  toLocation     String
  departureAt    DateTime
  returnAt       DateTime? // null = one-way
  passengerCount Int
  notes          String?   // purpose / special instructions
  // Contact person for this charter (may differ from account holder)
  contactName    String?
  contactPhone   String?
  contactEmail   String?
  status         String    @default("pending")
  // pending | quoted | payment_pending | confirmed | cancelled
  quotedPrice    Decimal?  @db.Decimal(12, 2)
  paymentRef     String?   @unique // Paystack reference — unique for idempotency
  paidAt         DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([passengerId])
  @@index([status])
  @@map("charters")
}

model Waybill {
  id             String         @id @default(uuid())
  waybillNo      String         @unique
  userId         String
  user           User           @relation(fields: [userId], references: [id])
  tripId         String?
  trip           Trip?          @relation(fields: [tripId], references: [id], onDelete: SetNull)
  senderName     String
  senderPhone    String
  recipientName  String
  recipientPhone String
  fromLocation   String
  toLocation     String
  description    String
  weightKg       Decimal?       @db.Decimal(8, 2)
  declaredValue  Decimal?       @db.Decimal(12, 2)
  fee            Decimal        @db.Decimal(12, 2)
  status         String         @default("pending")
  paymentRef     String?
  paidAt         DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  events         WaybillEvent[]

  @@index([waybillNo])
  @@index([status])
  @@map("waybills")
}

model WaybillEvent {
  id        String   @id @default(uuid())
  waybillId String
  waybill   Waybill  @relation(fields: [waybillId], references: [id], onDelete: Cascade)
  status    String
  location  String?
  note      String?
  createdAt DateTime @default(now())

  @@index([waybillId])
  @@map("waybill_events")
}
