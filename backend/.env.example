# Copy to .env and adjust. The app validates these at boot and refuses to start if invalid.
NODE_ENV=development
PORT=4000
DATABASE_URL=postgresql://transhub:transhub@localhost:5432/transhub?schema=public
REDIS_URL=redis://localhost:6379
CORS_ORIGIN=http://localhost:3000

# Auth — JWT_SECRET must be at least 16 chars. Generate one with: openssl rand -hex 32
JWT_SECRET=change_me_to_a_long_random_secret
JWT_EXPIRES_IN=7d

# Paystack — required at boot. Get these from your Paystack dashboard.
# Secret key (sk_test_… / sk_live_…) is server-only — never expose it to the client.
PAYSTACK_SECRET=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Public key (pk_test_… / pk_live_…) is safe to forward to the frontend.
PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Frontend base URL — used to build ticket/login links in emails.
FRONTEND_URL=http://localhost:3000

# Email (SMTP). In development these can stay blank: an Ethereal test account is
# auto-created and each email's preview URL is logged. In production SMTP_USER is
# required (the app refuses to boot without it).
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=TransHub <noreply@transhub.ng>
