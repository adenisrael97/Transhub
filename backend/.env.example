# Copy to .env and adjust. The app validates these at boot and refuses to start if invalid.
NODE_ENV=development
PORT=4000
DATABASE_URL=postgresql://transhub:transhub@localhost:5432/transhub?schema=public
REDIS_URL=redis://localhost:6379
CORS_ORIGIN=http://localhost:3000

# Auth — JWT_SECRET must be at least 16 chars. Generate one with: openssl rand -hex 32
JWT_SECRET=change_me_to_a_long_random_secret
JWT_EXPIRES_IN=7d

# Paystack — required at boot. Get these from your Paystack dashboard.
# Secret key (sk_test_… / sk_live_…) is server-only — never expose it to the client.
PAYSTACK_SECRET=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Public key (pk_test_… / pk_live_…) is safe to forward to the frontend.
PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Frontend base URL — used to build ticket/login links in emails.
FRONTEND_URL=http://localhost:3000

# Email (SMTP). In development these can stay blank: an Ethereal test account is
# auto-created and each email's preview URL is logged. In production SMTP_USER is
# required (the app refuses to boot without it).
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=TransHub <noreply@transhub.ng>

# ---------------------------------------------------------------------------
# Sentry (backend monitoring) — ALL OPTIONAL. Leave SENTRY_DSN empty to disable
# Sentry entirely (the SDK becomes a no-op; nothing is sent).
# ---------------------------------------------------------------------------
# Server DSN from the "transhub-backend" Sentry project (Settings → Client Keys).
SENTRY_DSN=
# Logical environment shown in Sentry: development | staging | production.
# Defaults to NODE_ENV when unset.
SENTRY_ENVIRONMENT=development
# Release identifier for regression tracking (e.g. the git SHA). Optional.
SENTRY_RELEASE=
# Tracing sample rate 0–1. Defaults to 1.0 in dev, 0.1 in prod when unset.
SENTRY_TRACES_SAMPLE_RATE=
# Performance thresholds (ms / bytes) for slow-query, slow-request, large-payload signals.
SLOW_REQUEST_MS=1000
SLOW_QUERY_MS=300
LARGE_PAYLOAD_BYTES=1000000
